# ─── Linear ───────────────────────────────────────────────────────────────────
# Required. Used to poll issues and (optionally) post progress comments.
# Generate at: https://linear.app/settings/api → Personal API keys
LINEAR_API_KEY=lin_api_...

# ─── Claude / Anthropic ───────────────────────────────────────────────────────
# Optional. If set, Claude Code uses this key instead of OAuth.
# Obtain at: https://console.anthropic.com/settings/keys
# If omitted, run `claude` once and use /login to authenticate via browser OAuth.
# ANTHROPIC_API_KEY=sk-ant-...
